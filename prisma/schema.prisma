// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Contact {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  area     String
  kakuyaku String @default("жњЄзўєзґ„") // "жњЄзўєзґ„" or "зўєзґ„"

  @@map("Submission")
}
